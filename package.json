{
  "name": "tecmogeek",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "rebuild:offense": "node scripts/rebuild-offensive-ratings.mjs",
    "rebuild:defense": "node scripts/rebuild-defensive-ratings.mjs",
    "rebuild:team-ratings": "node --experimental-strip-types --experimental-default-type=module scripts/rebuild-team-ratings.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "8.0.11",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "minimatch@3.1.5>brace-expansion": "1.1.14",
      "next>postcss": "8.5.14",
      "vite": "8.0.11"
    }
  }
}
